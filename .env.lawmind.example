# LawMind environment template
# Copy to .env.lawmind and fill only what you need.
#
# Example:
#   cp .env.lawmind.example .env.lawmind
#   source .env.lawmind
#   npm run lawmind:smoke
#
# Optional:
#   export LAWMIND_INTERACTIVE_REVIEW=1
#   npm run lawmind:smoke

# =============================================================================
# 0) Runtime toggles
# =============================================================================

# 1 = enable CLI review gate in smoke script
LAWMIND_INTERACTIVE_REVIEW=0

# Agent: OpenAI-compatible chat/completions HTTP timeout (ms). CLI default 60000; LawMind Desktop default 120000.
# LAWMIND_AGENT_TIMEOUT_MS=120000

# Agent: single tool execution budget (ms), e.g. execute_workflow / draft_document. Defaults to LAWMIND_AGENT_TIMEOUT_MS when unset.
# LAWMIND_TOOL_TIMEOUT_MS=180000

# M2 optional: model-driven task routing (needs LLM creds below or LAWMIND_AGENT_*)
# LAWMIND_ROUTER_MODE=model

# M2 optional: model-driven draft layout (needs LLM creds)
# LAWMIND_REASONING_MODE=model

# Optional overrides (default: same as agent / Qwen envs)
# LAWMIND_ROUTER_BASE_URL=
# LAWMIND_ROUTER_API_KEY=
# LAWMIND_ROUTER_MODEL=
# LAWMIND_REASONING_BASE_URL=
# LAWMIND_REASONING_API_KEY=
# LAWMIND_REASONING_MODEL=


# =============================================================================
# 1) Domestic general-model providers (OpenAI-compatible)
# Fill ONE OR MORE providers as needed.
# =============================================================================

# --- Qwen / DashScope ---
# Docs endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1
LAWMIND_QWEN_API_KEY=
LAWMIND_QWEN_MODEL=

# --- DeepSeek ---
# Endpoint: https://api.deepseek.com/v1
LAWMIND_DEEPSEEK_API_KEY=
LAWMIND_DEEPSEEK_MODEL=

# --- GLM / Zhipu ---
# Endpoint: https://open.bigmodel.cn/api/paas/v4
LAWMIND_GLM_API_KEY=
LAWMIND_GLM_MODEL=

# --- Moonshot / Kimi ---
# Endpoint: https://api.moonshot.cn/v1
LAWMIND_MOONSHOT_API_KEY=
LAWMIND_MOONSHOT_MODEL=

# --- SiliconFlow ---
# Endpoint: https://api.siliconflow.cn/v1
LAWMIND_SILICONFLOW_API_KEY=
LAWMIND_SILICONFLOW_MODEL=


# =============================================================================
# 2) Open-source legal models (self-hosted, OpenAI-compatible)
# =============================================================================

# --- ChatLaw (primary recommended for legal specialization) ---
LAWMIND_CHATLAW_BASE_URL=
LAWMIND_CHATLAW_API_KEY=local
LAWMIND_CHATLAW_MODEL=

# --- LaWGPT (backup option) ---
LAWMIND_LAWGPT_BASE_URL=
LAWMIND_LAWGPT_API_KEY=local
LAWMIND_LAWGPT_MODEL=


# =============================================================================
# 3) LexEdge integration (framework endpoint)
# =============================================================================

# Endpoint should return ModelRetrievalOutput-compatible JSON
LAWMIND_LEXEDGE_ENDPOINT=
LAWMIND_LEXEDGE_TOKEN=


# =============================================================================
# 4) Partner local legal model (future collaboration slot)
# =============================================================================

LAWMIND_PARTNER_LEGAL_BASE_URL=
LAWMIND_PARTNER_LEGAL_API_KEY=local
LAWMIND_PARTNER_LEGAL_MODEL=

