{
  "name": "lawmind",
  "version": "0.2.0",
  "private": true,
  "description": "LawMind — local-first lawyer workbench (desktop shell + legal engine)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lawmind:acceptance": "node --import tsx scripts/lawmind/lawmind-acceptance.ts",
    "lawmind:agent": "node --import tsx scripts/lawmind/lawmind-agent.ts",
    "lawmind:bundle:desktop-server": "npx --yes esbuild apps/lawmind-desktop/server/lawmind-local-server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=apps/lawmind-desktop/server/dist/lawmind-local-server.cjs",
    "lawmind:case": "node --import tsx scripts/lawmind/lawmind-case.ts",
    "lawmind:demo": "node --import tsx scripts/lawmind/lawmind-demo.ts",
    "lawmind:desktop": "pnpm --filter lawmind-desktop dev",
    "lawmind:desktop:dist": "pnpm --filter lawmind-desktop run dist:electron",
    "lawmind:desktop:e2e": "pnpm --filter lawmind-desktop test:e2e",
    "lawmind:desktop:http-smoke": "node scripts/lawmind/lawmind-desktop-http-smoke.mjs",
    "lawmind:docs:build": "pnpm --filter lawmind-docs build",
    "lawmind:docs:dev": "pnpm --filter lawmind-docs dev",
    "lawmind:docs:preview": "pnpm --filter lawmind-docs preview",
    "lawmind:env:check": "node --import tsx scripts/lawmind/lawmind-env-check.ts",
    "lawmind:gate": "node --import tsx scripts/lawmind/lawmind-deliverable-check.ts",
    "lawmind:onboard": "node --import tsx scripts/lawmind/lawmind-onboard.ts",
    "lawmind:ops": "node --import tsx scripts/lawmind/lawmind-ops.ts",
    "lawmind:review": "node --import tsx scripts/lawmind/lawmind-review.ts",
    "lawmind:sbom": "node scripts/lawmind/lawmind-sbom.mjs",
    "lawmind:sbom:cyclonedx": "sh -c 'cd apps/lawmind-desktop && pnpm dlx @cyclonedx/cyclonedx-npm@4.2.1 --ignore-npm-errors -o ../../dist/lawmind-sbom-cyclonedx-lawmind-desktop.json --spec-version 1.6'",
    "lawmind:setup": "node --import tsx scripts/lawmind/lawmind-quick-setup.ts",
    "lawmind:smoke": "node --import tsx scripts/lawmind/lawmind-smoke.ts",
    "lawmind:vendor:desktop-node": "node scripts/vendor-lawmind-desktop-node.mjs",
    "prepare": "command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath git-hooks || exit 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "jszip": "^3.10.1",
    "pptxgenjs": "^3.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.22.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
